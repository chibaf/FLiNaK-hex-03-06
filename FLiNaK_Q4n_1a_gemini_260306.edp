// FLiNaK_Q4n_1a_gemini_260306.edp
// FLiNaK溶融塩炉 - 実物理単位系による軸対称熱流体シミュレーション

bool debug = true;

// --- 1. 幾何形状パラメータ [m] ---
real w = 0.25;      // 容器半径
real H = 0.8;       // 容器高さ
real S = 0.1;       // 内部構造物下端
real H1 = 0.6;      // 内部構造物高さ
real d = 0.15;      // 内部構造物内径
real w1 = 0.03;     // 内部構造物厚み
real ch = 0.04;     // 面取り
real rpipe = 0.02;  // 中心軸回避用パイプ半径

// --- 2. 境界定義 ---
border C1(t=rpipe, w) {x=t; y=0; label=1;}
border C2(t=0, H-ch)  {x=w; y=t; label=2;}
border Chamfer(t=0, 1){x=w - t*ch; y=H-ch + t*ch; label=2;}
border C3(t=w-ch, rpipe) {x=t; y=H; label=3;}
border Cpipe(t=H, 0)  {x=rpipe; y=t; label=12;}

border D1(t=0, w1)    {x=d+t; y=S; label=20;}
border D2(t=S, S+H1)  {x=d+w1; y=t; label=20;}
border D3(t=0, pi)    {x=d+w1/2.0 + (w1/2.0)*cos(t); 
                       y=S+H1 + (w1/2.0)*sin(t); label=20;}
border D4(t=S+H1, S)  {x=d; y=t; label=20;}

// --- 3. メッシュ生成 ---
mesh Th = buildmesh(C1(20) + C2(80) + Chamfer(10) + C3(20) + Cpipe(80)
                    + D1(-20) + D2(-60) + D3(-40) + D4(-60));

// --- 4. 有限要素空間の定義 ---
fespace Ph(Th, P0);
fespace Vh(Th, P2), Qh(Th, P1);

Vh u=0, v=0, uu, vv, up, vp;
Qh p=0, pp;

// --- 5. 物理定数（SI単位系：FLiNaK） ---
real kelvin = 273.15;
real T_ref = 450.0 + kelvin;  // 基準温度
real low = T_ref;            // 冷却壁温度

real rho = 2.02e3;           // 密度 [kg/m^3]
real mu = 2.9e-3;            // 粘性係数 [Pa・s]
real nu = mu / rho;          // 動粘性係数 [m^2/s]
real Cp = 1.883e3;           // 比熱容量 [J/kg/K]
real kappa = 0.92;           // 熱伝導率 [W/m/K]
real rhoCp = rho * Cp;
real beta = 3.61e-4;         // 体積膨張係数 [1/K]
real g = 9.81;               // 重力加速度 [m/s^2] (本来の値)
real g_eff = 0.1;            // 計算安定化のための有効重力（徐々にgに近づける）

// 熱源設定
real Qpower = 50.0e3;        // 出力密度 [W/m^3] (例：50kW/m3)
real Q0 = Qpower / rhoCp;    // 温度上昇率 [K/s]
real V_pump = 0.02;          // 強制流速 [m/s]

// 熱源・ポンプ関数の定義
Qh fQ = ( (x >= rpipe && x < d) && (y >= S && y <= S+H1) ) ? Q0 : 0.0;
Ph fP = ( (x >= rpipe && x < d) && (y >= S && y <= S+S*0.1) ) ? V_pump : 0.0;

// --- 6. 時間積分パラメータ ---
real T = 200.0;              // 総計算時間
real dt = 0.05;              // 時間刻み
int n = 0;

Qh r = T_ref, rr, rp;        // 温度場

// --- 7. メインループ ---
for (real t=0; t<T; t+=dt){
    up = u; vp = v; rp = r;

    // --- Navier-Stokes方程式 (実単位系) ---
    solve NS([u,v,p], [uu,vv,pp], solver=Crout, init=n) =
    int2d(Th)( x * (
        (u*uu + v*vv)/dt
        + nu * (dx(u)*dx(uu) + dy(u)*dy(uu) + dx(v)*dx(vv) + dy(v)*dy(vv))
        - p * (dx(uu) + dy(vv) + uu/x) // 連続の式（軸対称項含む）
        + pp * (dx(u) + dy(v) + u/x) 
        + p*pp*1e-9                    // 数値安定化項
    ))
    - int2d(Th)( x * (
        (convect([up,vp], -dt, up)*uu + convect([up,vp], -dt, vp)*vv)/dt
        + beta * g_eff * (r - T_ref) * vv // 浮力（ブシネスク近似）
        + fP * vv / dt                    // ポンプ駆動力
    ))
    + on(1, 2, 3, 12, 20, u=0, v=0);

    // --- 熱伝導・移流方程式 (実単位系) ---
    // alpha = kappa / rhoCp を直接代入
    solve thermal(r, rr, solver=Crout, init=n) =
    int2d(Th)( x * (
        r * rr / dt
        + (kappa / rhoCp) * (dx(r)*dx(rr) + dy(r)*dy(rr))
    ))
    - int2d(Th)( x * (
        convect([up,vp], -dt, rp) * rr / dt
        + fQ * rr
    ))
    + on(1, 2, r=low); // 底部と側壁を冷却

    // --- 可視化 ---
    if (n%20 == 0) {
        Vh vel = sqrt(u*u + v*v);
        Vh TempC = r - kelvin; // 表示は摂氏で
        plot(TempC, [u,v], value=true, fill=true, cmm="Temp [C] at t="+t+"s");
    }
    n++;
}