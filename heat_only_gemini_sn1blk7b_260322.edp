// ==========================================================
// FLiNaK_Heat_Conduction_Final_v2.edp
// Fixed: Syntax error in volume integration (Line 58).
// ==========================================================

// --- 1. Parameters ---
real w = 0.25, H = 0.8, S = 0.1, H1 = 0.6, d = 0.15, w1 = 0.03;
real rpipe = 0.02, d2 = 0.01;
real PI = acos(-1.0);

// --- 2. Borders ---
border C1(t=rpipe, w-d2) {x=t; y=d2; label=1;}
border C2(t=d2, H){x=w-d2; y=t; label=2;}
border C3(t=w-d2, rpipe){x=t; y=H; label=3;} 
border Cpipe(t=H, d2){x=rpipe; y=t; label=12;}

border D1(t=0, w1) {x=d+t; y=S; label=20;}
border D2(t=S, S+H1) {x=d+w1; y=t; label=20;}
border D3(t=0, pi) {
    x = d + w1/2.0 + (w1/2.0)*cos(t); 
    y = S + H1 + (w1/2.0)*sin(t); 
    label=20;
}
border D4(t=S+H1, S) {x=d; y=t; label=20;}

border E1(t=d2, 0){x=rpipe; y=t; label=30;}
border E2(t=rpipe, w){x=t; y=0; label=30;}
border E3(t=0, H){x=w; y=t; label=30;}
border E4(t=w, w-d2){x=t; y=H; label=30;}

// --- 3. Mesh Generation ---
mesh Th = buildmesh(C1(20) + C2(80) + C3(20) + Cpipe(80) + 
                    D1(20) + D2(60) + D3(40) + D4(60) + 
                    E1(10) + E2(30) + E3(40) + E4(10));

// --- 4. Identify Region ---
// Get the ID of the shroud region
int regShroud = Th(d + w1/2.0, S + H1/2.0).region;

// --- 5. FE Spaces & Properties ---
fespace Vh(Th, P1);
fespace Ph(Th, P0);
Vh u, v;
Ph kappa, fQ;

real kFluid = 0.92, kShroud = 15.0;
real Qpower = 50.0e3, hOuter = 500.0, TExt = 450.0;

// Set property distributions
kappa = (region == regShroud) ? kShroud : kFluid;
fQ = ( (x >= rpipe && x < d) && (y >= S && y <= S+H1) ) ? Qpower : 0.0;

// --- 6. Volume Calculation (Fixed Syntax) ---
// Total Volume Theoretical
real Vtotal = PI * (w^2 - rpipe^2) * H;

// Shroud Volume: Integrate 2*PI*r over regShroud
real Vshroud = int2d(Th, regShroud)( 2.0 * PI * x ); 

// Fluid Volume: Use (region != regShroud) as a 1 or 0 multiplier
real Vfluid = int2d(Th)( (region != regShroud) * 2.0 * PI * x );

// --- 7. Solve ---
solve steadyHeat(u, v) = 
    int2d(Th)( x * kappa * (dx(u)*dx(v) + dy(u)*dy(v)) )
    + int1d(Th, 30)( x * hOuter * u * v )
    - int1d(Th, 30)( x * hOuter * TExt * v )
    - int2d(Th)( x * fQ * v );

// --- 8. Output ---
cout << "--- Results ---" << endl;
cout << "Shroud Region ID : " << regShroud << endl;
cout << "Shroud Volume    : " << Vshroud << " [m^3]" << endl;
cout << "Net Fluid Volume : " << Vfluid  << " [m^3]" << endl;
cout << "Max Temp         : " << u[].max << " [degC]" << endl;

plot(u, fill=1, value=1, wait=1, cmm="Final Corrected Simulation");